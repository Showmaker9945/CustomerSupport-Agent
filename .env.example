# LLM Configuration (Qwen default)
LLM_PROVIDER=qwen
LLM_MODEL=qwen-plus
LLM_HIGH_QUALITY_MODEL=qwen-max
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.7
LLM_API_KEY=your_qwen_api_key_here

# Backward compatibility (optional)
OPENAI_API_KEY=

# Application Settings
APP_NAME=CustomerSupport-Agent
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Server Settings
HOST=0.0.0.0
PORT=8000
WS_PORT=8001

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/support.db
POSTGRES_URI=postgresql://support_user:support_pass@localhost:5432/support?sslmode=disable
PGVECTOR_ENABLED=true

# LangGraph Persistence / Store
LANGGRAPH_PERSISTENCE_BACKEND=memory
LANGGRAPH_USE_POSTGRES=false
LANGGRAPH_THREAD_PREFIX=support
AUTO_SETUP_POSTGRES=true

# Vector Store (ChromaDB)
CHROMA_PERSIST_DIR=./data/chroma_db
COLLECTION_NAME=faq_knowledge_base
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=BAAI/bge-reranker-base
ENABLE_RERANKER=false

# Knowledge Base
KNOWLEDGE_BASE_PATH=./data/knowledge_base
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=3
RAG_TOP_K=4
RAG_FUSION_K=60
RAG_VECTOR_WEIGHT=0.6
RAG_KEYWORD_WEIGHT=0.4

# Conversation Memory
MEMORY_TYPE=sqlite
MAX_CONVERSATION_HISTORY=20
SESSION_TIMEOUT_HOURS=24
LONG_TERM_MEMORY_NAMESPACE=user_memory
MAX_MEMORY_ITEMS_PER_USER=100

# Sentiment Analysis
SENTIMENT_THRESHOLD=0.3
FRUSTRATION_KEYWORDS=["生气","愤怒","投诉","太差","离谱","angry","frustrated","terrible","awful","hate","stupid","useless"]

# Human Handoff
HANDOFF_THRESHOLD=-0.5
MAX_AI_TURNS=10
HUMAN_HANDOFF_MESSAGE="我正在为你转接人工客服，请稍等。"
HITL_HIGH_RISK_TOOLS=["create_ticket","update_ticket","escalate_to_human"]

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=60
MAX_WS_CONNECTIONS_PER_USER=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Localization
DEFAULT_RESPONSE_LANGUAGE=zh-CN
